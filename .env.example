# Web
NEXT_PUBLIC_REALTIME_HTTP_URL=http://localhost:4001
NEXT_PUBLIC_REALTIME_WS_URL=ws://localhost:4002

# Realtime
HTTP_PORT=4001
HOCUSPOCUS_PORT=4002
# Supabase Postgres connection string (Transaction pooler or direct DB URL)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
AGENT_API_URL=http://localhost:8001

# Agent
LLM_PROVIDER=stub

# Upstash Redis (recommended)
UPSTASH_REDIS_REST_URL=https://<your-db>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<your-upstash-rest-token>
# Optional explicit Redis URL override (if provided by Upstash)
# UPSTASH_REDIS_URL=rediss://default:<password>@<your-db>.upstash.io:6379/0
# Optional local fallback
# REDIS_URL=redis://localhost:6379/0
